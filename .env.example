# Copie este arquivo para .env e preencha os valores

# Chave secreta para JWT (MUDE ISTO - use uma string longa e aleatória)
JWT_SECRET=mude-para-uma-chave-longa-e-secreta-aqui-1234567890abcdef

# Porta do servidor (padrão: 3000)
PORT=3000

# Caminho do banco de dados SQLite (padrão: igreja.db na raiz do projeto)
DB_PATH=igreja.db
